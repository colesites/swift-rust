{
  "name": "swift-rust-docs",
  "version": "0.1.0",
  "private": true,
  "description": "Documentation site for the swift-rust framework.",
  "type": "module",
  "scripts": {
    "prebuild": "bunx turbo run build --filter='swift-rust...'",
    "dev": "bun ../packages/swift-rust/bin/dev-server.mjs --port 3001",
    "build": "bun ../packages/swift-rust/bin/build.mjs",
    "start": "bun ../packages/swift-rust/bin/dev-server.mjs --port 3001",
    "lint": "biome check --no-errors-on-unmatched $(pwd)/app",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .swift-rust .vercel .turbo dist"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "swift-rust": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^6.0.0"
  }
}
