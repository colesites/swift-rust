{
  "name": "@swift-rust/ui",
  "version": "0.3.0",
  "description": "shadcn-style component registry for swift-rust.",
  "license": "MIT",
  "homepage": "https://swift-rust.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/colesites/swift-rust.git",
    "directory": "packages/ui"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "swift-rust": "./dist/cli.js"
  },
  "files": [
    "dist",
    "registry",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check --no-errors-on-unmatched $(pwd)/src",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/colesites/swift-rust/issues"
  }
}
