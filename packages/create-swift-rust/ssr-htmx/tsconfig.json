{
  "extends": "swift-rust/tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",
    "paths": {
      "@": [
        "src/*"
      ]
    }
  },
  "include": [
    "src/**/*",
    ".swift-rust/types/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".swift-rust",
    ".turbo"
  ]
}
