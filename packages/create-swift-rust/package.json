{
  "name": "create-swift-rust",
  "version": "0.8.2",
  "description": "Create a new swift-rust project from a template.",
  "license": "MIT",
  "homepage": "https://swift-rust.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/colesites/swift-rust.git",
    "directory": "packages/create-swift-rust"
  },
  "bugs": {
    "url": "https://github.com/colesites/swift-rust/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "create-swift-rust": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/sync-template.mjs",
    "prepack": "node scripts/sync-template.mjs",
    "sync-template": "node scripts/sync-template.mjs",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check $(pwd)/src",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo templates"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "picocolors": "^1.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
