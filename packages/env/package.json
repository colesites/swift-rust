{
  "name": "@swift-rust/env",
  "version": "0.1.0",
  "description": "Loads .env files and exposes validated environment variables.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./load": {
      "types": "./dist/load.d.ts",
      "import": "./dist/load.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check /Users/admin/Documents/programming/projects/k-bench/swift-rust/packages/env/src",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.0.0"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
