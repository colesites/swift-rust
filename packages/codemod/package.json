{
  "name": "@swift-rust/codemod",
  "version": "0.1.0",
  "description": "Automated refactors for swift-rust projects.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "transforms"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check --no-errors-on-unmatched $(pwd)/src",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@babel/parser": "^7.25.0",
    "@babel/traverse": "^7.25.0",
    "@babel/generator": "^7.25.0"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.20.0",
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swift-rust/swift-rust.git",
    "directory": "packages/codemod"
  },
  "bugs": {
    "url": "https://github.com/swift-rust/swift-rust/issues"
  },
  "homepage": "https://swift-rust.dev"
}
