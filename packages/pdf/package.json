{
  "name": "@swift-rust/pdf",
  "version": "0.2.0",
  "description": "PDF component tree and viewer for swift-rust.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./viewer": {
      "types": "./dist/viewer.d.ts",
      "import": "./dist/viewer.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "biome check --no-errors-on-unmatched $(pwd)/src",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "pdfjs-dist": "^4.7.0"
  },
  "peerDependencies": {
    "react": "^18 || ^19"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^6.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/swift-rust/swift-rust.git",
    "directory": "packages/pdf"
  },
  "bugs": {
    "url": "https://github.com/swift-rust/swift-rust/issues"
  },
  "homepage": "https://swift-rust.dev"
}
