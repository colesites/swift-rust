# External URLs — override per environment (e.g. Vercel project env vars).
# When unset, production fallbacks in app/src/site.config.ts are used.
SWIFT_RUST_SITE_URL=https://swift-rust-self.vercel.app
SWIFT_RUST_DOCS_URL=https://docs-swift-rust.vercel.app
SWIFT_RUST_GITHUB_URL=https://github.com/colesites/swift-rust
