{
  "name": "swift-rust",
  "version": "0.1.0",
  "private": true,
  "description": "The full-stack React framework powered with Rust + Bun. Inspired by Next.js. 10x faster.",
  "license": "MIT",
  "homepage": "https://swift-rust.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/colesites/swift-rust.git"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs",
    "scripts",
    "test",
    "examples/*",
    "test/fixtures/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:rust": "cargo build --workspace",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:rust": "cargo test --workspace",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && cargo clean",
    "format": "cargo fmt --all && bun run --filter '*' format",
    "changeset": "changeset",
    "release": "turbo run build && changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.27.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.0.0",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "turbo": "^2.1.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.5",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "bunx biome check --write"
    ],
    "*.{rs,.toml}": [
      "cargo fmt --"
    ]
  }
}
